OPENAI_API_KEY=sk-your-key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=netease-youdao/bce-embedding-base_v1
EMBEDDING_DIMENSION=768
OPENAI_MAX_TOKENS=2048
OPENAI_DISABLE_THINKING=true
DATABASE_URL=sqlite+aiosqlite:///./travel_agent.db
REDIS_URL=redis://localhost:6379/0
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_LITE_PATH=./milvus_lite.db
LOG_LEVEL=INFO
WORKSPACE_DIR=workspace
DEFAULT_AGENT_ID=travel-agent
ENABLE_MEMORY_VECTOR_STORE=true
ENABLE_LOCAL_EMBEDDINGS_FALLBACK=true
